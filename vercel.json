{
  "buildCommand": "cd app && npm install && npm run build",
  "outputDirectory": "app/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/notices/:id", "destination": "/api/notices?id=:id" },
    { "source": "/api/checklist/:id", "destination": "/api/checklist?id=:id" },
    { "source": "/api/estimate-revisions/:id", "destination": "/api/estimate-revisions?id=:id" },
    { "source": "/api/reports/:id", "destination": "/api/reports?id=:id" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
